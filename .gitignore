# 环境变量与敏感信息（勿提交）
.env

# 忽略所有 zip 文件（解决你的大文件问题）
*.zip

# 忽略IDE配置目录（如PyCharm的.idea）
.idea/

# 忽略Python编译生成的__pycache__目录及.pyc文件
__pycache__/
*.pyc

# 忽略.specstory目录
.specstory/

# 忽略.cursorindexingignore文件
.cursorindexingignore

# 忽略.cursorignore文件
.cursorignore

# 忽略.cursorrules文件
.cursorrules

# 忽略.cursorignore文件
.cursorignore

# 忽略literature_pdfs目录下的oa目录和non_oa目录、google_scholar目录
literature_pdfs/oa/*
literature_pdfs/non_oa/*
literature_pdfs/google_scholar/*

# 忽略.vscode目录
.vscode/
