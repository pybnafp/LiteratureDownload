# 复制此文件为 .env 并填写真实值（.env 已被 git 忽略，不会提交）
# 邮箱（用于 PubMed、Unpaywall 等 API）
EMAIL=your_email@example.com
# PubMed API 密钥（可选，可提高请求速率）
PUBMED_API_KEY=
# Selenium：无头模式（默认 true，Ubuntu SSH 不弹 Chrome 窗口）。本地调试可设为 false
SELENIUM_HEADLESS=true
# Google Scholar API（searchapi.io）：批量脚本 batch_speech_disorder_downloader 是否启用 OA 失败后的 Scholar 兜底
# 设为 true/1/yes 且填写有效 GOOGLE_SCHOLAR_API_KEY 后才会启用；默认不启用
USE_GOOGLE_SCHOLAR=true
GOOGLE_SCHOLAR_API_KEY=
# 通义 DashScope API Key（用于 LLM 解析参考文献），可选
DASHSCOPE_API_KEY=
